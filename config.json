{
  "app": {
    "name": "SonFED",
    "default_timeframe": "15m",
    "default_period": "5d",
    "local_only": true
  },
  "tickers": {
    "GOLD": "GC=F",
    "DXY": "DX-Y.NYB",
    "US10Y": "^TNX",
    "US02Y": "^IRX",
    "VIX": "^VIX",
    "OIL": "CL=F",
    "NASDAQ": "QQQ",
    "SP500": "SPY"
  },
  "telegram": {
    "enabled": false,
    "cycle_minutes": 30
  },
  "auto_refresh": {
    "enabled": true,
    "interval_minutes": 5
  },
  "trade": {
    "mode": "Tự động",
    "symbol": "XAUUSD",
    "allow_auto_trade": false,
    "min_confidence": 60,
    "max_spread_points": 45,
    "max_drawdown_percent": 5,
    "max_open_positions": 3,
    "signal_max_age_seconds": 300,
    "default_lot": 0.03
  },
  "features": {
    "indicators": {
      "bollinger": true,
      "ma20": true,
      "ema50": true,
      "ema200": true,
      "rsi": true,
      "macd": true,
      "adx": true,
      "atr": true,
      "volume": true
    },
    "strategies": {
      "Scalp BUY momentum M15": true,
      "Scalp SELL momentum M15": true,
      "Scalp breakout M15": true,
      "Scalp reject M15": true,
      "Hồi kỹ thuật": true,
      "SELL theo xu hướng": true,
      "Breakout": true,
      "Reject": true,
      "Sideway": true,
      "Né tin": true,
      "Đảo chiều tăng": true,
      "Tiếp diễn giảm": true
    }
  },
  "paths": {
    "shared_dir": "C:\\SonFED\\shared",
    "fallback_shared_dir": "shared",
    "database": "data\\sonfed.db",
    "events": "events.csv"
  },
  "trade_policy": {
    "symbol": "XAUUSD",
    "allow_buy": true,
    "allow_sell": true,
    "max_buy_orders": 3,
    "max_sell_orders": 3,
    "default_lot": 0.03,
    "max_buy_volume": 0.09,
    "max_sell_volume": 0.09,
    "min_confidence": 60,
    "min_rr": 1.0,
    "max_spread": 45,
    "filter_high_volatility": true,
    "filter_important_news": true,
    "allow_sonexec_read_signal": false,
    "allow_auto_execution": false,
    "allow_auto_adjustment": false,
    "position_management_strategy": "Bám xu hướng"
  }
}
